{
  "name": "glide-scale-extension",
  "private": true,
  "version": "0.1.0",
  "description": "GLIDE Chrome extension for SCALE workflow enhancements.",
  "author": "Blake Becker",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "format": "prettier --write .",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @blakebecker/glide-extension test:e2e",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.7.0",
    "eslint": "^9.12.0",
    "globals": "^17.5.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.59.0"
  }
}
